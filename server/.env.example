# ============================================
# Bit Ticket - Backend Environment Variables
# ============================================

# Servidor
PORT=3001

# Base de Datos (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=bit_ticket

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=24h

# Reserva temporal de boletos (minutos)
RESERVATION_TIMEOUT_MINUTES=10
